---
---
<section>
    <div class="slide-content bg-background text-on-surface font-body-lg antialiased selection:bg-glow-cyan selection:text-background">
        <div class="h-full w-full flex items-center justify-center relative overflow-hidden snap-start bg-surface">
            
            <div class="absolute inset-0 bg-grid-pattern opacity-5"></div>
            <div class="max-w-container-max w-full px-gutter relative z-10">
                <div class="flex items-center justify-between mb-stack-lg border-b border-border-subtle pb-stack-sm">
                    <h2 class="font-headline-lg text-headline-lg text-inverse-surface border-l-2 border-glow-cyan pl-stack-md">Valor Estratégico</h2>
                    <span class="font-mono-data text-mono-data text-glow-cyan">ECONOMIC_IMPACT</span>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
                    <!-- Empleo Calificado -->
                    <div class="bg-surface-container-low border border-border-subtle p-stack-lg relative overflow-hidden flex flex-col justify-between h-52">
                        <div class="absolute top-0 left-0 w-full h-[3px] bg-glow-cyan"></div>
                        <div>
                            <span class="font-mono-data text-label-caps text-glow-cyan block mb-4">TALENTO</span>
                            <span class="material-symbols-outlined text-[36px] text-glow-cyan mb-2">badge</span>
                            <h3 class="font-headline-md text-inverse-surface">Empleo Calificado</h3>
                        </div>
                        <p class="font-body-sm text-text-muted">Puestos formales con salarios por encima de la media.</p>
                    </div>

                    <!-- Exportaciones de Alto Valor -->
                    <div class="bg-surface-container-low border border-border-subtle p-stack-lg relative overflow-hidden flex flex-col justify-between h-52">
                        <div class="absolute top-0 left-0 w-full h-[3px] bg-glow-cyan"></div>
                        <div>
                            <span class="font-mono-data text-label-caps text-glow-cyan block mb-4">INDUSTRIA</span>
                            <span class="material-symbols-outlined text-[36px] text-glow-cyan mb-2">rocket_launch</span>
                            <h3 class="font-headline-md text-inverse-surface">Servicios de Valor</h3>
                        </div>
                        <p class="font-body-sm text-text-muted">Digitalización y modernización de sectores tradicionales.</p>
                    </div>

                    <!-- Ingreso de Divisas -->
                    <div class="bg-surface-container-low border border-border-subtle p-stack-lg relative overflow-hidden flex flex-col justify-between h-52">
                        <div class="absolute top-0 left-0 w-full h-[3px] bg-glow-cyan"></div>
                        <div>
                            <span class="font-mono-data text-label-caps text-glow-cyan block mb-4">DIVISAS</span>
                            <span class="material-symbols-outlined text-[36px] text-glow-cyan mb-2">payments</span>
                            <h3 class="font-headline-md text-inverse-surface">Ingreso de Divisas</h3>
                        </div>
                        <p class="font-body-sm text-text-muted">Exportaciones clave para el balance comercial nacional.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
