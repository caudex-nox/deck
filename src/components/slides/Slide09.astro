---
---
<section>
    <div class="slide-content bg-background text-on-surface font-body-lg antialiased selection:bg-glow-cyan selection:text-background">
        <div class="h-full w-full flex items-center justify-center relative overflow-hidden snap-start bg-surface-container-lowest">
            
            <div class="absolute inset-0 bg-grid-pattern opacity-5"></div>
            <div class="max-w-container-max w-full px-gutter relative z-10">
                <div class="flex items-center justify-between mb-stack-lg border-b border-border-subtle pb-stack-sm">
                    <h2 class="font-headline-lg text-headline-lg text-inverse-surface border-l-2 border-glow-cyan pl-stack-md">Diferencias Operativas</h2>
                    <span class="font-mono-data text-mono-data text-glow-cyan">OPERATIONAL_MODELS</span>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
                    <!-- Corporaciones -->
                    <div class="bg-surface border border-border-subtle p-stack-lg relative overflow-hidden group flex flex-col justify-between">
                        <div class="absolute top-0 left-0 w-full h-[3px] bg-outline-variant"></div>
                        <div class="text-center py-6">
                            <span class="font-mono-data text-label-caps text-text-muted block mb-stack-sm">GIGANTES DEL SECTOR</span>
                            <h3 class="font-headline-md text-headline-md text-inverse-surface mb-stack-lg flex justify-center items-center gap-2">
                                <span class="material-symbols-outlined text-outline">dns</span> Productos & SaaS
                            </h3>
                            
                            <div class="flex flex-col gap-3 max-w-[280px] mx-auto">
                                <span class="px-4 py-2 bg-surface-container-low border border-border-subtle text-sm font-bold text-inverse-surface">Licenciamiento SaaS</span>
                                <span class="px-4 py-2 bg-surface-container-low border border-border-subtle text-sm font-bold text-inverse-surface">Integraciones Masivas</span>
                                <span class="px-4 py-2 bg-surface-container-low border border-border-subtle text-sm font-bold text-inverse-surface">Metodologías Rígidas</span>
                            </div>
                        </div>
                    </div>

                    <!-- PyMEs -->
                    <div class="bg-surface border border-glow-cyan/30 p-stack-lg relative overflow-hidden group flex flex-col justify-between shadow-[0_0_20px_rgba(0,240,255,0.02)]">
                        <div class="absolute top-0 left-0 w-full h-[3px] bg-glow-cyan"></div>
                        <div class="text-center py-6">
                            <span class="font-mono-data text-label-caps text-glow-cyan block mb-stack-sm">MOTOR PYME</span>
                            <h3 class="font-headline-md text-headline-md text-inverse-surface mb-stack-lg flex justify-center items-center gap-2">
                                <span class="material-symbols-outlined text-glow-cyan">code_blocks</span> Fábricas & Servicios
                            </h3>
                            
                            <div class="flex flex-col gap-3 max-w-[280px] mx-auto">
                                <span class="px-4 py-2 bg-surface-container-low border border-glow-cyan/35 text-sm font-bold text-glow-cyan">Software a Medida (Ad-hoc)</span>
                                <span class="px-4 py-2 bg-surface-container-low border border-glow-cyan/35 text-sm font-bold text-glow-cyan">Consultoría de Cercanía</span>
                                <span class="px-4 py-2 bg-surface-container-low border border-glow-cyan/35 text-sm font-bold text-glow-cyan">Staff Augmentation</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
