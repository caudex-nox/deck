---
---
<section>
    <div class="slide-content bg-background text-on-surface font-body-lg antialiased selection:bg-glow-cyan selection:text-background">
        <div class="h-full w-full flex items-center justify-center relative overflow-hidden snap-start bg-surface-container-lowest">

            <div class="max-w-container-max w-full px-gutter grid grid-cols-1 md:grid-cols-2 gap-gutter relative z-10">
                <div class="flex flex-col justify-center">
                    <h2 class="font-headline-lg text-headline-lg text-inverse-surface mb-stack-sm">Hub Tecnológico Local</h2>
                    <h3 class="font-headline-md text-headline-md text-glow-cyan mb-stack-md">Cluster TIC Santa Fe</h3>
                    <div class="flex gap-stack-md mb-stack-lg">
                        <div class="bg-surface border border-border-subtle p-stack-sm px-stack-md flex-1 text-center">
                            <span class="block font-headline-md text-inverse-surface">&gt; 30</span>
                            <span class="font-mono-data text-label-caps text-text-muted">Empresas</span>
                        </div>
                        <div class="bg-surface border border-border-subtle p-stack-sm px-stack-md flex-1 text-center">
                            <span class="block font-headline-md text-inverse-surface">&gt; 800</span>
                            <span class="font-mono-data text-label-caps text-text-muted">Puestos de Trabajo</span>
                        </div>
                    </div>
                    <p class="font-body-md text-body-md text-on-surface-variant mb-stack-md">Ecosistema colaborativo enfocado en la innovación y exportación regional.</p>
                    <div class="grid grid-cols-2 gap-stack-sm">
                        <div class="bg-surface border border-border-subtle p-stack-sm">
                            <span class="font-mono-data text-inverse-surface block mb-1">i2T SA</span>
                            <span class="font-body-sm text-text-muted text-xs">Transformación digital.</span>
                        </div>
                        <div class="bg-surface border border-border-subtle p-stack-sm">
                            <span class="font-mono-data text-inverse-surface block mb-1">Crombie</span>
                            <span class="font-body-sm text-text-muted text-xs">Software internacional.</span>
                        </div>
                        <div class="bg-surface border border-border-subtle p-stack-sm">
                            <span class="font-mono-data text-inverse-surface block mb-1">Folder IT</span>
                            <span class="font-body-sm text-text-muted text-xs">Consultoría y desarrollo.</span>
                        </div>
                        <div class="bg-surface border border-border-subtle p-stack-sm">
                            <span class="font-mono-data text-inverse-surface block mb-1">Serfe</span>
                            <span class="font-body-sm text-text-muted text-xs">Desarrollo web a medida.</span>
                        </div>
                    </div>
                </div>
                <div class="relative h-full min-h-[400px] border border-border-subtle bg-surface flex items-center justify-center overflow-hidden">
                    <img alt="Map Data" class="absolute inset-0 w-full h-full object-cover opacity-50 grayscale" src="/images/map-bg.webp"/>
                    <div class="absolute inset-0 bg-gradient-to-tr from-surface via-transparent to-surface-container-low opacity-80"></div>
                    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 flex flex-col items-center">
                        <div class="relative flex h-6 w-6">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-glow-cyan opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-6 w-6 bg-glow-cyan"></span>
                        </div>
                        <span class="font-mono-data text-label-caps text-glow-cyan mt-3 bg-surface-container-lowest px-3 py-1 border border-glow-cyan/30">SANTA_FE_CORE</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

