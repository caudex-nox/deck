<section>
    <div class="slide-content bg-background text-on-surface font-body-lg antialiased selection:bg-glow-cyan selection:text-background">
        <div class="h-full w-full flex items-center justify-center relative overflow-hidden snap-start bg-surface">
            
            <div class="absolute inset-0 bg-grid-pattern opacity-5"></div>
            <div class="max-w-container-max w-full px-gutter relative z-10">
                <div class="flex items-center justify-between mb-stack-lg border-b border-border-subtle pb-stack-sm">
                    <h2 class="font-headline-lg text-headline-lg text-inverse-surface border-l-2 border-glow-cyan pl-stack-md">Ventajas y Arraigo Local</h2>
                    <span class="font-mono-data text-mono-data text-glow-cyan">PYME_BENEFITS</span>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
                    <!-- Trato Cercano -->
                    <div class="bg-surface-container-low border border-border-subtle p-stack-lg flex flex-col justify-between relative overflow-hidden">
                        <span class="absolute right-4 top-2 font-mono-data text-[70px] text-surface-variant/30 font-black select-none">01</span>
                        <div class="relative z-10">
                            <span class="material-symbols-outlined text-[36px] text-glow-cyan mb-stack-sm">handshake</span>
                            <h3 class="font-headline-md text-headline-md text-inverse-surface mb-stack-sm">Trato Cercano</h3>
                            <p class="font-body-sm text-text-muted">Relación directa y personalizada de confianza.</p>
                        </div>
                    </div>

                    <!-- Procesos Ágiles -->
                    <div class="bg-surface-container-low border border-border-subtle p-stack-lg flex flex-col justify-between relative overflow-hidden">
                        <span class="absolute right-4 top-2 font-mono-data text-[70px] text-surface-variant/30 font-black select-none">02</span>
                        <div class="relative z-10">
                            <span class="material-symbols-outlined text-[36px] text-glow-cyan mb-stack-sm">bolt</span>
                            <h3 class="font-headline-md text-headline-md text-inverse-surface mb-stack-sm">Procesos Ágiles</h3>
                            <p class="font-body-sm text-text-muted">Estructuras planas para una rápida adaptabilidad.</p>
                        </div>
                    </div>

                    <!-- Retención de Talento Regional -->
                    <div class="bg-surface-container-low border border-border-subtle p-stack-lg flex flex-col justify-between relative overflow-hidden">
                        <span class="absolute right-4 top-2 font-mono-data text-[70px] text-surface-variant/30 font-black select-none">03</span>
                        <div class="relative z-10">
                            <span class="material-symbols-outlined text-[36px] text-glow-cyan mb-stack-sm">home</span>
                            <h3 class="font-headline-md text-headline-md text-inverse-surface mb-stack-sm">Desarrollo Federal</h3>
                            <p class="font-body-sm text-text-muted">Generación de empleo técnico sin migración provincial.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
