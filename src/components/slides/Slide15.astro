---
---
<section>
    <div class="slide-content bg-background text-on-surface font-body-lg antialiased selection:bg-glow-cyan selection:text-background">
        <div class="h-full w-full flex">
            <!-- Izquierda: Contenido y Desafíos -->
            <div class="w-1/2 h-full flex flex-col justify-center px-stack-lg bg-surface">
                <div class="flex items-center gap-2 mb-stack-sm text-error">
                    <span class="material-symbols-outlined text-[24px]">warning</span>
                    <span class="font-mono-data text-label-caps tracking-[0.15em]">EL OBSTÁCULO PRINCIPAL</span>
                </div>
                <h2 class="font-headline-lg text-headline-lg text-inverse-surface mb-stack-lg border-l-2 border-error pl-stack-md">Retención de<br/>Talento</h2>
                
                <div class="flex flex-col gap-stack-md">
                    <div class="flex items-center gap-stack-md bg-surface-container-low border border-border-subtle p-stack-sm w-full max-w-[420px]">
                        <span class="material-symbols-outlined text-error text-[28px]">currency_exchange</span>
                        <div>
                            <h3 class="font-headline-md text-inverse-surface text-sm">Competencia Cambiaria</h3>
                            <p class="font-body-sm text-text-muted">Ofertas directas del exterior en USD.</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-stack-md bg-surface-container-low border border-border-subtle p-stack-sm w-full max-w-[420px]">
                        <span class="material-symbols-outlined text-error text-[28px]">flight_takeoff</span>
                        <div>
                            <h3 class="font-headline-md text-inverse-surface text-sm">Fuga de Seniors</h3>
                            <p class="font-body-sm text-text-muted">Pérdida de mentores y líderes técnicos.</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-stack-md bg-surface-container-low border border-border-subtle p-stack-sm w-full max-w-[420px]">
                        <span class="material-symbols-outlined text-error text-[28px]">corporate_fare</span>
                        <div>
                            <h3 class="font-headline-md text-inverse-surface text-sm">Vulnerabilidad PyME</h3>
                            <p class="font-body-sm text-text-muted">Mayor rotación y dificultad para competir.</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Derecha: Imagen de Impacto -->
            <div class="w-1/2 h-full relative overflow-hidden border-l border-border-subtle bg-surface-container-lowest">
                <div class="absolute inset-0 bg-cover bg-center opacity-60" style="background-image: url('/images/slide_challenge.webp');"></div>
                <div class="absolute inset-0 bg-gradient-to-l from-transparent via-background/40 to-background"></div>
                <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-background/40"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                    <span class="font-mono-data text-label-caps text-error border border-error/40 bg-background/80 px-4 py-2 shadow-[0_0_15px_rgba(255,0,0,0.15)]">COMPETITIVE_ALERT</span>
                </div>
            </div>
        </div>
    </div>
</section>
