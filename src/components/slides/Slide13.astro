---
---
<section>
    <div class="slide-content bg-background text-on-surface font-body-lg antialiased selection:bg-glow-cyan selection:text-background">
        <div class="h-full w-full flex">
            <!-- Izquierda: Imagen + Overlay -->
            <div class="w-1/2 h-full relative overflow-hidden border-r border-border-subtle bg-surface-container-lowest">
                <div class="absolute inset-0 bg-cover bg-center opacity-60" style="background-image: url('/images/slide_remote_work.webp');"></div>
                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-background/40 to-background"></div>
                <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-background/40"></div>
                <div class="relative z-10 flex flex-col justify-center h-full px-stack-lg">
                    <span class="font-mono-data text-label-caps text-glow-cyan block mb-stack-sm">NUEVO PARADIGMA</span>
                    <h2 class="font-headline-lg text-headline-lg text-inverse-surface mb-stack-sm leading-tight">Trabajo sin<br/>Fronteras</h2>
                </div>
            </div>
            
            <!-- Derecha: Tarjetas de Contenido -->
            <div class="w-1/2 h-full flex flex-col justify-center px-stack-lg bg-surface">
                <div class="flex items-center justify-between mb-stack-lg border-b border-border-subtle pb-stack-sm">
                    <span class="font-mono-data text-mono-data text-glow-cyan">WORK_EVOLUTION</span>
                </div>
                <div class="flex flex-col gap-stack-lg">
                    <!-- Equipos Distribuidos -->
                    <div class="flex items-start gap-stack-md">
                        <span class="material-symbols-outlined text-[36px] text-glow-cyan">distance</span>
                        <div>
                            <h3 class="font-headline-md text-inverse-surface mb-1">Equipos Distribuidos</h3>
                            <p class="font-body-md text-text-muted">Colaboración remota y asincrónica con mercados globales.</p>
                        </div>
                    </div>

                    <!-- Integración de IA -->
                    <div class="flex items-start gap-stack-md border-t border-border-subtle pt-stack-lg">
                        <span class="material-symbols-outlined text-[36px] text-glow-cyan">assistant</span>
                        <div>
                            <h3 class="font-headline-md text-inverse-surface mb-1">Productividad con IA</h3>
                            <p class="font-body-md text-text-muted">Uso diario de copilotos de código para acelerar el desarrollo.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
