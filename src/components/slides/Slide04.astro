---
---
<section>
    <div class="slide-content bg-background text-on-surface font-body-lg antialiased selection:bg-glow-cyan selection:text-background">
        <div class="h-full w-full flex items-center justify-center relative overflow-hidden snap-start bg-surface">

            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-surface-container-low via-surface to-surface"></div>
            <div class="max-w-container-max w-full px-gutter relative z-10 flex flex-col h-full justify-center">
                <div class="flex items-center justify-between mb-stack-lg border-b border-border-subtle pb-stack-sm">
                    <h2 class="font-headline-lg text-headline-lg text-inverse-surface">Líderes Nacionales</h2>
                    <span class="font-mono-data text-mono-data text-glow-cyan">MARKET_OVERVIEW</span>
                </div>
                <div class="overflow-x-auto bg-surface-container-lowest border border-border-subtle p-stack-sm">
                    <table class="w-full text-table-sm">
                        <thead>
                            <tr>
                                <th class="p-stack-sm font-mono-data text-label-caps">Empresa</th>
                                <th class="p-stack-sm font-mono-data text-label-caps">Tipo</th>
                                <th class="p-stack-sm font-mono-data text-label-caps">Servicios</th>
                                <th class="p-stack-sm font-mono-data text-label-caps">Mercado</th>
                                <th class="p-stack-sm font-mono-data text-label-caps">Empleados</th>
                                <th class="p-stack-sm font-mono-data text-label-caps">Tecnologías</th>
                            </tr>
                        </thead>
                        <tbody class="font-mono-data">
                            <tr class="hover:bg-surface-container-low transition-colors">
                                <td class="p-stack-sm text-inverse-surface">Globant</td>
                                <td class="p-stack-sm">Servicios IT</td>
                                <td class="p-stack-sm">Desarrollo a medida, Consultoría</td>
                                <td class="p-stack-sm">Global</td>
                                <td class="p-stack-sm">&gt; 30k</td>
                                <td class="p-stack-sm">IA, Cloud, Ciberseguridad</td>
                            </tr>
                            <tr class="hover:bg-surface-container-low transition-colors">
                                <td class="p-stack-sm text-inverse-surface">Mercado Libre</td>
                                <td class="p-stack-sm">Producto / Plataforma</td>
                                <td class="p-stack-sm">E-commerce, Fintech</td>
                                <td class="p-stack-sm">LATAM</td>
                                <td class="p-stack-sm">&gt; 80k</td>
                                <td class="p-stack-sm">Big Data, Cloud, IA</td>
                            </tr>
                            <tr class="hover:bg-surface-container-low transition-colors">
                                <td class="p-stack-sm text-inverse-surface">Accenture</td>
                                <td class="p-stack-sm">Consultoría Global</td>
                                <td class="p-stack-sm">Estrategia, Digital, Operaciones</td>
                                <td class="p-stack-sm">Global</td>
                                <td class="p-stack-sm">&gt; 15k (Arg)</td>
                                <td class="p-stack-sm">SAP, Salesforce, Cloud</td>
                            </tr>
                            <tr class="hover:bg-surface-container-low transition-colors">
                                <td class="p-stack-sm text-inverse-surface">Baufest</td>
                                <td class="p-stack-sm">Servicios IT</td>
                                <td class="p-stack-sm">Desarrollo, Innovación</td>
                                <td class="p-stack-sm">Regional / Global</td>
                                <td class="p-stack-sm">&gt; 900</td>
                                <td class="p-stack-sm">Java, .NET, Cloud</td>
                            </tr>
                            <tr class="hover:bg-surface-container-low transition-colors">
                                <td class="p-stack-sm text-inverse-surface">Santex</td>
                                <td class="p-stack-sm">Software Factory</td>
                                <td class="p-stack-sm">Web, Mobile, IA</td>
                                <td class="p-stack-sm">Global</td>
                                <td class="p-stack-sm">&gt; 700</td>
                                <td class="p-stack-sm">React, Node, IA</td>
                            </tr>
                            <tr class="hover:bg-surface-container-low transition-colors border-b-0">
                                <td class="p-stack-sm text-inverse-surface">Endava</td>
                                <td class="p-stack-sm">Servicios IT</td>
                                <td class="p-stack-sm">Ingeniería, Pagos, Media</td>
                                <td class="p-stack-sm">Global</td>
                                <td class="p-stack-sm">&gt; 1k (Arg)</td>
                                <td class="p-stack-sm">Arquitectura, Cloud, Agile</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

