---
---
<section>
    <div class="slide-content bg-background text-on-surface font-body-lg antialiased selection:bg-glow-cyan selection:text-background">
        <div class="h-full w-full flex items-center justify-center relative overflow-hidden snap-start bg-surface">
            
            <div class="absolute inset-0 bg-grid-pattern opacity-5"></div>
            <div class="max-w-container-max w-full px-gutter relative z-10">
                <div class="flex items-center justify-between mb-stack-lg border-b border-border-subtle pb-stack-sm">
                    <h2 class="font-headline-lg text-headline-lg text-inverse-surface border-l-2 border-glow-cyan pl-stack-md">Perfiles Demandados</h2>
                    <span class="font-mono-data text-mono-data text-glow-cyan">DEMANDED_ROLES</span>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-stack-md">
                    <!-- Web & Mobile -->
                    <div class="bg-surface-container-low border border-border-subtle p-stack-md flex flex-col justify-between h-28 relative group">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-glow-cyan text-[24px]">devices</span>
                            <h3 class="font-headline-md text-inverse-surface">Web & Mobile</h3>
                        </div>
                        <span class="font-mono-data text-xs text-glow-cyan block">React • Node.js • Kotlin • Swift</span>
                    </div>

                    <!-- Ciencia de Datos & IA -->
                    <div class="bg-surface-container-low border border-border-subtle p-stack-md flex flex-col justify-between h-28 relative group">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-glow-cyan text-[24px]">query_stats</span>
                            <h3 class="font-headline-md text-inverse-surface">Ciencia de Datos & IA</h3>
                        </div>
                        <span class="font-mono-data text-xs text-glow-cyan block">Python • SQL • PyTorch • BigQuery</span>
                    </div>

                    <!-- Ciberseguridad -->
                    <div class="bg-surface-container-low border border-border-subtle p-stack-md flex flex-col justify-between h-28 relative group">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-glow-cyan text-[24px]">shield</span>
                            <h3 class="font-headline-md text-inverse-surface">Ciberseguridad</h3>
                        </div>
                        <span class="font-mono-data text-xs text-glow-cyan block">SecOps • IAM • Cloud Security • Pentesting</span>
                    </div>

                    <!-- Diseño UX/UI -->
                    <div class="bg-surface-container-low border border-border-subtle p-stack-md flex flex-col justify-between h-28 relative group">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-glow-cyan text-[24px]">palette</span>
                            <h3 class="font-headline-md text-inverse-surface">Diseño UX/UI</h3>
                        </div>
                        <span class="font-mono-data text-xs text-glow-cyan block">Figma • Wireframing • User Research</span>
                    </div>

                    <!-- Análisis de Sistemas -->
                    <div class="bg-surface-container-low border border-border-subtle p-stack-md flex flex-col justify-between h-28 relative group">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-glow-cyan text-[24px]">schema</span>
                            <h3 class="font-headline-md text-inverse-surface">Análisis de Sistemas</h3>
                        </div>
                        <span class="font-mono-data text-xs text-glow-cyan block">UML • SCRUM • Requerimientos</span>
                    </div>

                    <!-- Bases de Datos & Cloud -->
                    <div class="bg-surface-container-low border border-border-subtle p-stack-md flex flex-col justify-between h-28 relative group">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-glow-cyan text-[24px]">database</span>
                            <h3 class="font-headline-md text-inverse-surface">Bases de Datos & Cloud</h3>
                        </div>
                        <span class="font-mono-data text-xs text-glow-cyan block">PostgreSQL • NoSQL • Docker • AWS</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
