---
---
<section>
    <div class="slide-content bg-background text-on-surface font-body-lg antialiased selection:bg-glow-cyan selection:text-background">
        <div class="h-full w-full flex items-center justify-center relative overflow-hidden snap-start bg-surface-container-lowest">

            <div class="max-w-container-max w-full px-gutter">
                <h2 class="font-headline-lg text-headline-lg text-inverse-surface mb-stack-lg text-center">Gigantes Nacionales</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
                    <!-- Globant -->
                    <div class="bg-surface-raised border border-border-subtle relative overflow-hidden flex flex-col h-full">
                        <div class="absolute top-0 left-0 w-full h-[3px] bg-glow-cyan"></div>
                        <div class="h-32 bg-surface-container-high bg-cover bg-center relative opacity-40" style="background-image: url('/images/globant-bg.webp');">
                            <div class="absolute inset-0 bg-gradient-to-t from-surface-raised to-transparent"></div>
                        </div>
                        <div class="p-stack-lg relative z-10 flex-grow text-center">
                            <h3 class="font-headline-md text-headline-md text-inverse-surface mb-1">Globant</h3>
                            <span class="block font-headline-xl text-[60px] text-glow-cyan font-black leading-none mb-4">+30.000</span>
                            <span class="font-mono-data text-xs text-text-muted uppercase tracking-wider block">Colaboradores Globales</span>
                            
                            <div class="flex flex-wrap justify-center gap-2 mt-6">
                                <span class="px-3 py-1 bg-surface-container-high border border-border-subtle text-xs font-mono-data text-inverse-surface">Inteligencia Artificial</span>
                                <span class="px-3 py-1 bg-surface-container-high border border-border-subtle text-xs font-mono-data text-inverse-surface">Transformación Digital</span>
                            </div>
                        </div>
                    </div>
                    <!-- Mercado Libre -->
                    <div class="bg-surface-raised border border-border-subtle relative overflow-hidden flex flex-col h-full">
                        <div class="absolute top-0 left-0 w-full h-[3px] bg-glow-cyan"></div>
                        <div class="h-32 bg-surface-container-high bg-cover bg-center relative opacity-40" style="background-image: url('/images/meli-bg.webp');">
                            <div class="absolute inset-0 bg-gradient-to-t from-surface-raised to-transparent"></div>
                        </div>
                        <div class="p-stack-lg relative z-10 flex-grow text-center">
                            <h3 class="font-headline-md text-headline-md text-inverse-surface mb-1">Mercado Libre</h3>
                            <span class="block font-headline-xl text-[60px] text-glow-cyan font-black leading-none mb-4">+80.000</span>
                            <span class="font-mono-data text-xs text-text-muted uppercase tracking-wider block">Colaboradores Regionales</span>
                            
                            <div class="flex flex-wrap justify-center gap-2 mt-6">
                                <span class="px-3 py-1 bg-surface-container-high border border-border-subtle text-xs font-mono-data text-inverse-surface">E-commerce & Fintech</span>
                                <span class="px-3 py-1 bg-surface-container-high border border-border-subtle text-xs font-mono-data text-inverse-surface">Logística & Cloud</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
