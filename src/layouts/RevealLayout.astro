---
import 'reveal.js/reveal.css';
import 'reveal.js/theme/black.css'; // Tema por defecto
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Deck</title>
	</head>
	<body>
		<slot />

		<!-- Botón Home -->
		<button class="home-btn" id="homeBtn" style="display: none;">Inicio</button>

		<!-- Botón Fullscreen -->
		<button id="fullscreenBtn" class="fullscreen-btn">Fullscreen</button>

		<!-- Paginación por puntos -->
		<div class="pagination-dots" id="paginationDots"></div>

		<!-- Botones navegación -->
		<div class="nav-overlay">
			<button id="prevBtn">◀</button>
			<button id="nextBtn">▶</button>
		</div>
		
		<script>
			import Reveal from 'reveal.js';
			
			document.addEventListener('DOMContentLoaded', () => {
				const deck = new Reveal({
					controls: false,
					progress: false,
					center: true,
					hash: false,
					transition: 'slide'
				});

				const homeBtn = document.getElementById('homeBtn');
				const fullscreenBtn = document.getElementById('fullscreenBtn');
				const paginationDots = document.getElementById('paginationDots');

				const updateHomeBtnVisibility = () => {
					if (homeBtn) {
						homeBtn.style.display = deck.isLastSlide() ? 'block' : 'none';
					}
				};

				const updatePagination = () => {
					if (!paginationDots) return;
					
					const slides = deck.getHorizontalSlides();
					const totalSlides = slides.length;
					const currentSlide = deck.getIndices().h;
					
					paginationDots.innerHTML = '';
					for (let i = 0; i < totalSlides; i++) {
						const dot = document.createElement('div');
						dot.classList.add('dot');
						dot.style.cursor = 'pointer';
						if (i === currentSlide) {
							dot.classList.add('active');
						}
						
						dot.addEventListener('click', () => {
							deck.slide(i);
						});

						paginationDots.appendChild(dot);
					}
				};

				const toggleFullscreen = () => {
					if (!document.fullscreenElement) {
						document.documentElement.requestFullscreen();
					} else {
						if (document.exitFullscreen) {
							document.exitFullscreen();
						}
					}
				};

				const updateFullscreenBtn = () => {
					if (fullscreenBtn) {
						fullscreenBtn.textContent = document.fullscreenElement ? 'Windowed' : 'Fullscreen';
					}
				};

				deck.initialize().then(() => {
					updateHomeBtnVisibility();
					updatePagination();

					// Eventos de botones
					document.getElementById('prevBtn')?.addEventListener('click', () => deck.prev());
					document.getElementById('nextBtn')?.addEventListener('click', () => deck.next());
					homeBtn?.addEventListener('click', () => deck.slide(0));

					fullscreenBtn?.addEventListener('click', toggleFullscreen);
					document.addEventListener('fullscreenchange', updateFullscreenBtn);

					deck.on('slidechanged', () => {
						updateHomeBtnVisibility();
						updatePagination();
					});
				});
			});
		</script>
	</body>
</html>

<style is:global>
	/* Esto asegura que la presentación ocupe toda la pantalla */
	html,
	body {
		margin: 0;
		padding: 0;
		width: 100%;
		height: 100%;
		overflow: hidden;
		background: #000;
	}

	/* Botones superpuestos */
	.nav-overlay {
		position: fixed;
		top: 50%;
		left: 0;
		right: 0;
		display: flex;
		justify-content: space-between;
		align-items: center;
		transform: translateY(-50%);
		pointer-events: none;
		padding: 0 20px;
		z-index: 1000;
	}

	.nav-overlay button {
		pointer-events: auto;
		background: rgba(0, 0, 0, 0.15);
		color: #fff;
		border: none;
		border-radius: 6px;
		cursor: pointer;
		font-weight: bold;
		transition: background 0.3s ease, opacity 0.3s ease, transform 0.1s ease;
		user-select: none;
		line-height: 1;
		opacity: 0.4;
	}

	.nav-overlay button:active {
		transform: scale(0.85);
	}

	#prevBtn, #nextBtn {
		width: 24px;
		height: 24px;
		font-size: 10px;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0;
	}

	.fullscreen-btn {
		position: fixed;
		bottom: 12px;
		right: 12px;
		background: rgba(255, 255, 255, 0.05);
		color: #fff;
		border: none;
		border-radius: 6px;
		cursor: pointer;
		font-weight: bold;
		font-size: 9px;
		padding: 6px 10px;
		opacity: 0.2;
		z-index: 1001;
		transition: background 0.3s ease, opacity 0.3s ease, transform 0.1s ease;
		user-select: none;
		line-height: 1;
	}

	.fullscreen-btn:active {
		transform: scale(0.95);
	}

	.fullscreen-btn:hover, .nav-overlay button:hover, .home-btn:hover {
		background: rgba(255, 255, 255, 0.2);
		opacity: 1;
	}

	/* Botón Home */
	.home-btn {
		position: fixed;
		top: 20px;
		left: 50%;
		transform: translateX(-50%);
		background: rgba(0, 0, 0, 0.15);
		color: #fff;
		border: none;
		padding: 7px 12px;
		border-radius: 6px;
		cursor: pointer;
		font-weight: bold;
		font-size: 10px;
		z-index: 1001;
		transition: background 0.3s ease, opacity 0.3s ease, transform 0.1s ease;
		line-height: 1;
		user-select: none;
		opacity: 0.4;
	}

	.home-btn:active {
		transform: translateX(-50%) scale(0.95);
	}

	/* Paginación por puntos */
	.pagination-dots {
		position: fixed;
		bottom: 20px;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		gap: 8px;
		z-index: 1000;
		pointer-events: none;
	}

	.dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.2);
		transition: background 0.3s ease, transform 0.2s ease;
		pointer-events: auto;
	}

	.dot:active {
		transform: scale(0.7);
	}

	.dot.active {
		background: rgba(255, 255, 255, 0.9);
		box-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
		animation: pulse 2s infinite ease-in-out;
	}

	@keyframes pulse {
		0%, 100% { opacity: 0.6; transform: scale(1); }
		50% { opacity: 1; transform: scale(1.1); }
	}
</style>
