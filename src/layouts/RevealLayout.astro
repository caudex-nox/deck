---
import 'reveal.js/reveal.css';
import { ChevronLeft, ChevronRight, House } from '@lucide/astro';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet"/>

		<script is:inline src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

		<script is:inline>
			(function() {
				tailwind.config = {
					darkMode: "class",
					theme: {
						extend: {
							"colors": {
								"surface": "#121212",
								"surface-variant": "#333535",
								"surface-tint": "#c9c6c5",
								"on-tertiary-fixed-variant": "#474746",
								"on-tertiary-fixed": "#1c1b1b",
								"inverse-surface": "#e2e2e2",
								"on-secondary": "#00363a",
								"surface-container-low": "#1a1c1c",
								"primary-container": "#0a0a0a",
								"on-primary": "#313030",
								"secondary-fixed-dim": "#00dbe9",
								"surface-container-highest": "#333535",
								"error-container": "#93000a",
								"on-tertiary": "#313030",
								"inverse-primary": "#5f5e5e",
								"outline": "#8e9192",
								"on-error-container": "#ffdad6",
								"on-error": "#690005",
								"glow-cyan": "#00F0FF",
								"surface-raised": "#121212",
								"surface-bright": "#38393a",
								"on-primary-container": "#7b7979",
								"secondary-container": "#00eefc",
								"secondary-fixed": "#7df4ff",
								"surface-container-lowest": "#121212",
								"tertiary": "#c8c6c5",
								"on-secondary-container": "#00686f",
								"error": "#ffb4ab",
								"primary": "#c9c6c5",
								"surface-container-high": "#282a2b",
								"on-secondary-fixed-variant": "#004f54",
								"tertiary-fixed-dim": "#c8c6c5",
								"text-muted": "#A1A1AA",
								"outline-variant": "#444748",
								"tertiary-fixed": "#e5e2e1",
								"tertiary-container": "#0a0a0a",
								"on-surface-variant": "#c4c7c7",
								"on-surface": "#e2e2e2",
								"on-tertiary-container": "#7a7979",
								"border-subtle": "#262626",
								"surface-container": "#1e2020",
								"secondary": "#d3fbff",
								"surface-dim": "#121212",
								"on-secondary-fixed": "#002022",
								"on-background": "#e2e2e2",
								"background": "#121212",
								"electric-blue": "#007BFF",
								"on-primary-fixed-variant": "#474646",
								"inverse-on-surface": "#2f3131",
								"on-primary-fixed": "#1c1b1b",
								"primary-fixed-dim": "#c9c6c5",
								"primary-fixed": "#e5e2e1"
							},
							"borderRadius": {
								"DEFAULT": "0.125rem",
								"lg": "0.25rem",
								"xl": "0.5rem",
								"full": "0.75rem"
							},
							"spacing": {
								"stack-sm": "8px",
								"stack-md": "16px",
								"margin-mobile": "20px",
								"gutter": "32px",
								"stack-lg": "32px",
								"section-gap": "80px",
								"container-max": "1280px"
							},
							"fontFamily": {
								"headline-md": ["Inter"],
								"label-caps": ["Inter"],
								"headline-lg": ["Inter"],
								"body-md": ["Inter"],
								"body-lg": ["Inter"],
								"headline-xl": ["Inter"],
								"headline-lg-mobile": ["Inter"],
								"mono-data": ["JetBrains Mono"]
							},
							"fontSize": {
								"headline-md": ["16px", { "lineHeight": "1.4", "fontWeight": "600" }],
								"label-caps": ["12px", { "lineHeight": "1", "letterSpacing": "0.1em", "fontWeight": "600" }],
								"headline-lg": ["40px", { "lineHeight": "1.2", "letterSpacing": "-0.01em", "fontWeight": "700" }],
								"body-md": ["16px", { "lineHeight": "1.6", "fontWeight": "400" }],
								"body-lg": ["18px", { "lineHeight": "1.6", "fontWeight": "400" }],
								"headline-xl": ["60px", { "lineHeight": "1.1", "letterSpacing": "-0.02em", "fontWeight": "800" }],
								"headline-lg-mobile": ["32px", { "lineHeight": "1.2", "fontWeight": "700" }],
								"mono-data": ["14px", { "lineHeight": "1.5", "fontWeight": "400" }],
								"body-sm": ["14px", { "lineHeight": "1.5", "fontWeight": "400" }],
								"table-sm": ["13px", { "lineHeight": "1.4", "fontWeight": "400" }]
							}
						}
					}
				}
			})();
		</script>

		<style is:inline>
			::-webkit-scrollbar {
				width: 0px;
				background: transparent;
			}
			.bg-grid-pattern {
				background-image: linear-gradient(to right, #262626 1px, transparent 1px),
								linear-gradient(to bottom, #262626 1px, transparent 1px);
				background-size: 40px 40px;
				background-position: center center;
			}
			table {
				border-collapse: collapse;
				width: 100%;
			}
			th, td {
				border-bottom: 1px solid #262626;
				text-align: left;
			}
			th {
				background-color: #1a1c1c;
				color: #e2e2e2;
				font-weight: 600;
			}
			td {
				background-color: #121212;
				color: #c4c7c7;
			}
			.slide-content {
				width: 100%;
				height: 100%;
				overflow: hidden;
			}
		</style>
		<meta name="generator" content={Astro.generator} />
		<title>Deck</title>
	</head>
	<body>
		<slot />

		<!-- Botón Home -->
		<button class="home-btn" id="homeBtn" style="display: none;">
			<House size={16} stroke-width={2.5} />
		</button>

		<!-- Botón Fullscreen -->
		<button id="fullscreenBtn" class="fullscreen-btn">Pantalla completa</button>

		<!-- Botón Overview -->
		<button id="overviewBtn" class="overview-btn">Vista general</button>

		<!-- Paginación por puntos -->
		<div class="pagination-dots" id="paginationDots"></div>

		<!-- Botones navegación -->
		<div class="nav-overlay">
			<button id="prevBtn">
				<ChevronLeft size={16} stroke-width={2.5} />
			</button>
			<button id="nextBtn">
				<ChevronRight size={16} stroke-width={2.5} />
			</button>
		</div>
		
		<script>
			import Reveal from 'reveal.js';
			
			document.addEventListener('DOMContentLoaded', () => {
				const deck = new Reveal({
					controls: false,
					progress: false,
					center: false,
					hash: false,
					transition: 'slide',
					transitionSpeed: 'fast',
					width: '100%',
					height: '100%',
					margin: 0,
					minScale: 1,
					maxScale: 1
				});

				const homeBtn = document.getElementById('homeBtn');
				const fullscreenBtn = document.getElementById('fullscreenBtn');
				const overviewBtn = document.getElementById('overviewBtn');
				const paginationDots = document.getElementById('paginationDots');

				const updateHomeBtnVisibility = () => {
					if (homeBtn) {
						homeBtn.style.display = deck.isLastSlide() ? 'block' : 'none';
					}
				};

				const updateOverviewBtn = () => {
					if (overviewBtn) {
						overviewBtn.textContent = deck.isOverview() ? 'Cerrar vista' : 'Vista general';
					}
				};

				const updatePagination = () => {
					if (!paginationDots) return;
					
					const slides = deck.getHorizontalSlides();
					const totalSlides = slides.length;
					const currentSlide = deck.getIndices().h;
					
					paginationDots.innerHTML = '';
					for (let i = 0; i < totalSlides; i++) {
						const dot = document.createElement('div');
						dot.classList.add('dot');
						dot.style.cursor = 'pointer';
						if (i === currentSlide) {
							dot.classList.add('active');
						}
						
						dot.addEventListener('click', () => {
							deck.slide(i);
						});

						paginationDots.appendChild(dot);
					}
				};

				const toggleFullscreen = () => {
					if (!document.fullscreenElement) {
						document.documentElement.requestFullscreen();
					} else {
						if (document.exitFullscreen) {
							document.exitFullscreen();
						}
					}
				};

				const updateFullscreenBtn = () => {
					if (fullscreenBtn) {
						fullscreenBtn.textContent = document.fullscreenElement ? 'Minimizar' : 'Pantalla completa';
					}
				};

				deck.initialize().then(() => {
					updateHomeBtnVisibility();
					updatePagination();

					// Eventos de botones
					document.getElementById('prevBtn')?.addEventListener('click', () => deck.prev());
					document.getElementById('nextBtn')?.addEventListener('click', () => deck.next());
					homeBtn?.addEventListener('click', () => deck.slide(0));

					fullscreenBtn?.addEventListener('click', toggleFullscreen);
					document.addEventListener('fullscreenchange', updateFullscreenBtn);

					overviewBtn?.addEventListener('click', () => deck.toggleOverview());
					deck.on('overviewshown', updateOverviewBtn);
					deck.on('overviewhidden', updateOverviewBtn);

					deck.on('slidechanged', () => {
						updateHomeBtnVisibility();
						updatePagination();
					});
				});
			});
		</script>
	</body>
</html>

<style is:global>
	/* Esto asegura que la presentación ocupe toda la pantalla */
	html,
	body {
		margin: 0;
		padding: 0;
		width: 100%;
		height: 100%;
		overflow: hidden;
		background-color: #121212;
	}

	.reveal {
		background-color: #121212;
	}

	.reveal .slides {
		inset: 0 !important;
		width: 100% !important;
		height: 100% !important;
	}

	.reveal .slides section {
		padding: 0;
		backface-visibility: hidden;
		width: 100% !important;
		height: 100% !important;
		min-height: 100% !important;
	}

	/* Estilos específicos para diapositivas de plantilla/default */
	.default-slide {
		display: flex !important;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		text-align: center;
		color: #ffffff;
		font-family: 'Inter', sans-serif;
	}

	.default-slide ul {
		list-style-position: inside;
		padding: 0;
		margin: 0;
		text-align: center;
	}

	.default-slide li {
		list-style-type: disc;
	}

	/* Botones superpuestos */
	.nav-overlay {
		position: fixed;
		top: 50%;
		left: 0;
		right: 0;
		display: flex;
		justify-content: space-between;
		align-items: center;
		transform: translateY(-50%);
		pointer-events: none;
		padding: 0 20px;
		z-index: 1000;
	}

	.nav-overlay button {
		pointer-events: auto;
		background: rgba(0, 0, 0, 0.15);
		color: #fff;
		border: none;
		border-radius: 6px;
		cursor: pointer;
		font-weight: bold;
		transition: background 0.3s ease, opacity 0.3s ease, transform 0.1s ease;
		user-select: none;
		line-height: 1;
		opacity: 0.4;
	}

	.nav-overlay button:active {
		transform: scale(0.85);
	}

	#prevBtn, #nextBtn {
		width: 24px;
		height: 24px;
		font-size: 10px;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0;
	}

	.fullscreen-btn {
		position: fixed;
		bottom: 12px;
		right: 12px;
		background: rgba(255, 255, 255, 0.05);
		color: #fff;
		border: none;
		border-radius: 6px;
		cursor: pointer;
		font-weight: bold;
		font-size: 9px;
		padding: 6px 10px;
		opacity: 0.2;
		z-index: 1001;
		transition: background 0.3s ease, opacity 0.3s ease, transform 0.1s ease;
		user-select: none;
		line-height: 1;
	}

	.fullscreen-btn:active {
		transform: scale(0.95);
	}

	.overview-btn {
		position: fixed;
		bottom: 12px;
		left: 12px;
		background: rgba(255, 255, 255, 0.05);
		color: #fff;
		border: none;
		border-radius: 6px;
		cursor: pointer;
		font-weight: bold;
		font-size: 9px;
		padding: 6px 10px;
		opacity: 0.2;
		z-index: 1001;
		transition: background 0.3s ease, opacity 0.3s ease, transform 0.1s ease;
		user-select: none;
		line-height: 1;
	}

	.overview-btn:active {
		transform: scale(0.95);
	}

	.fullscreen-btn:hover, .nav-overlay button:hover, .home-btn:hover, .overview-btn:hover {
		background: rgba(255, 255, 255, 0.2);
		opacity: 1;
	}

	/* Botón Home */
	.home-btn {
		position: fixed;
		top: 20px;
		left: 50%;
		transform: translateX(-50%);
		background: rgba(0, 0, 0, 0.15);
		color: #fff;
		border: none;
		padding: 7px 12px;
		border-radius: 6px;
		cursor: pointer;
		font-weight: bold;
		font-size: 10px;
		z-index: 1001;
		transition: background 0.3s ease, opacity 0.3s ease, transform 0.1s ease;
		line-height: 1;
		user-select: none;
		opacity: 0.4;
	}

	.home-btn:active {
		transform: translateX(-50%) scale(0.95);
	}

	/* Paginación por puntos */
	.pagination-dots {
		position: fixed;
		bottom: 20px;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		gap: 8px;
		z-index: 1000;
		pointer-events: none;
	}

	.dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.2);
		transition: background 0.3s ease, transform 0.2s ease;
		pointer-events: auto;
	}

	.dot:active {
		transform: scale(0.7);
	}

	.dot.active {
		background: rgba(255, 255, 255, 0.9);
		box-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
		animation: pulse 2s infinite ease-in-out;
	}

	@keyframes pulse {
		0%, 100% { opacity: 0.6; transform: scale(1); }
		50% { opacity: 1; transform: scale(1.1); }
	}
</style>
